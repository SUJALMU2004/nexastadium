# OpenRouter API key. Keep this secret. Never expose it to the frontend.
OPENROUTER_API_KEY=

# OpenRouter model slug. Use a concrete free-tier model slug from OpenRouter.
OPENROUTER_MODEL=poolside/laguna-xs-2.1:free

# OpenRouter API base URL.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional site URL for OpenRouter app attribution.
OPENROUTER_SITE_URL=http://localhost:5173

# Optional app name for OpenRouter app attribution.
OPENROUTER_APP_NAME=NexaStadium AI

# JSON array of browser origins allowed to call the FastAPI backend.
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:3000","http://127.0.0.1:3000"]

# Runtime environment label used in health checks and conditional diagnostics.
ENVIRONMENT=development

# Default API rate limit per client IP address.
RATE_LIMIT_PER_MINUTE=30
